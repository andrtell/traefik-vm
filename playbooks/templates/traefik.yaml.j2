providers:
  docker:
    endpoint: "unix:///var/run/docker.sock"
    exposedByDefault: false

log:
  level: INFO

api:
  dashboard: true

certificatesResolvers:
  letsencrypt:
    acme:
      email: "{{ lets_encrypt_email }}"
      storage: "/acme.json"
      tlschallenge: true

entrypoints:
  web:
    address: ":80"
{% if force_https %}
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
{% endif %}
  websecure:
    address: ":443"
  traefik:
    address: ":8080"
